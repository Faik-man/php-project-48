#!/usr/bin/env php

<?php

$autoloadPath1 = __DIR__ . '/../../../autoload.php';
$autoloadPath2 = __DIR__ . '/../vendor/autoload.php';
if (file_exists($autoloadPath1)) {
    require_once $autoloadPath1;
} else {
    require_once $autoloadPath2;
}

use App\JsonParser;

$doc = <<<DOC
Generate diff

Usage:
  gendiff (-h|--help)
  gendiff (-v|--version)
  gendiff [--format <fmt>] <firstFile> <secondFile>

Options:
  -h --help                     Show this screen
  -v --version                  Show version
  --format <fmt>                Report format [default: stylish]
DOC;

$response = Docopt::handle($doc);
if ($response->success && empty(array_diff(['<firstFile>', '<secondFile>'], array_keys($response->args)))) {
    $firstFilePath = $response['<firstFile>'];
    $secondFilePath = $response['<secondFile>'];

    $normalizedFirstFilePath = realpath($firstFilePath);
    $normalizedSecondFilePath = realpath($secondFilePath);

    if ($normalizedFirstFilePath === false) {
        throw new Exception("Not found first file by path: {$firstFilePath}!");
    }

    if ($normalizedSecondFilePath === false) {
        throw new Exception("Not found second file by path: {$secondFilePath}!");
    }

    $firstFileContent = file_get_contents($normalizedFirstFilePath);
    $secondFileContent = file_get_contents($normalizedSecondFilePath);

    try {
        $firstFileData = JsonParser\parse($firstFileContent);
        $secondFileData = JsonParser\parse($secondFileContent);
    } catch(\Exception $e) {
        echo $e, PHP_EOL;
        die;
    }

    echo $firstFileContent, PHP_EOL;
    echo $secondFileContent, PHP_EOL;
}
